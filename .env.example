# ─── Required ─────────────────────────────────────────────────────────────
# Postgres connection (docker-compose provides this automatically).
POSTGRES_URL=postgresql+psycopg2://arxiv:arxiv@localhost:5432/arxiv_rag

# OpenAI (only required if EMBEDDING_BACKEND=openai or for GPT-4o-mini generation).
OPENAI_API_KEY=sk-...

# ─── Vector store ─────────────────────────────────────────────────────────
VECTOR_BACKEND=chroma          # "chroma" (local) or "pinecone" (production)
CHROMA_PATH=./chroma_db
PINECONE_API_KEY=
PINECONE_INDEX=arxiv-rag
PINECONE_NAMESPACE=cs-lg
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ─── Embeddings ───────────────────────────────────────────────────────────
# "local"  -> sentence-transformers/all-MiniLM-L6-v2 (384 dims, free, no key)
# "openai" -> text-embedding-3-small (1536 dims, needs OPENAI_API_KEY)
EMBEDDING_BACKEND=local

# ─── Reranker ─────────────────────────────────────────────────────────────
# "local"  -> cross-encoder/ms-marco-MiniLM-L-6-v2 (free, no key)
# "cohere" -> rerank-english-v3.0 (needs COHERE_API_KEY)
RERANKER_BACKEND=local
COHERE_API_KEY=

# ─── Generation ───────────────────────────────────────────────────────────
# "groq"   -> Llama 3.3 70B on Groq's free OpenAI-compatible API (no credit card)
# "openai" -> gpt-4o-mini (needs OPENAI_API_KEY)
# "echo"   -> deterministic offline stub (no key; for tests/demo without an LLM)
LLM_BACKEND=groq
LLM_MODEL=gpt-4o-mini
# Groq: get a free key at https://console.groq.com/keys (no card required).
GROQ_API_KEY=
# 8b-instant is fast with a generous free daily limit; 70b-versatile is higher
# quality but capped at 100k tokens/day on the free tier.
GROQ_MODEL=llama-3.1-8b-instant

# ─── Ingestion knobs ──────────────────────────────────────────────────────
MAX_PAPERS=500
ARXIV_CATEGORY=cs.LG
ARXIV_START_DATE=2023-01-01
ARXIV_END_DATE=2024-12-31
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ─── Misc ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_URL=http://localhost:8000

# ─── Production / deployment (docker-compose.prod.yml + nginx + certbot) ───
# Public domain pointing at the VM's static public IP (DNS A record).
DOMAIN=arxiv-rag.example.com
# Email Let's Encrypt uses for expiry notices.
CERTBOT_EMAIL=you@example.com
# Postgres password used by the production compose stack (do NOT commit real value).
POSTGRES_PASSWORD=change-me
